<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.sofirv.waterlilies">

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_game"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_game"
        android:supportsRtl="true"
        android:theme="@style/Theme.WaterLillies"
        tools:targetApi="31">

        <activity android:name=".main_app.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.sofirv.waterlilies.main_app.HomeActivity"
            android:exported="true"
            android:screenOrientation="portrait">
        </activity>
        <activity
            android:name="com.sofirv.waterlilies.duckgame.SplashActivity"
            android:exported="true"
            android:screenOrientation="landscape" />
        <activity
            android:name="com.sofirv.waterlilies.duckgame.MenuActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name="com.sofirv.waterlilies.duckgame.GameActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name="com.sofirv.waterlilies.duckgame.LevelSelectActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name="com.sofirv.waterlilies.game2048.MainActivity2048"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name="com.sofirv.waterlilies.main_app.ScoresActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name="com.sofirv.waterlilies.main_app.ScoreSearchActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>
</manifest>